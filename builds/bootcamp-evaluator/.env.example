# Provider: "anthropic" | "openai" | "openrouter" | "ollama"
PROVIDER=openrouter

# Model identifier (provider-specific)
# OpenRouter: anthropic/claude-sonnet-4-6, google/gemini-2.5-flash
# Anthropic: claude-sonnet-4-6, claude-haiku-4-5-20251001
# OpenAI: gpt-4o, gpt-4o-mini
# Ollama: llama3, mistral
MODEL=anthropic/claude-sonnet-4-6

# API keys (set the one matching your PROVIDER)
OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Composio — replaces individual API keys for GitHub, Reddit, Google, etc.
# Get yours at https://composio.dev
COMPOSIO_API_KEY=

# Ollama base URL (only needed for PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Max output tokens (optional, default: 16384)
# MAX_TOKENS=16384
