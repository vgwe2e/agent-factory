# =============================================================
# Agent Factory — Environment Configuration
# =============================================================
# Only 2 keys needed. Composio replaces all individual API keys
# (Serper, GitHub, Reddit, etc.) with a single managed platform.
# =============================================================

# --- LLM Provider --------------------------------------------
# OpenRouter gives access to all major models through one API.
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# --- Composio ------------------------------------------------
# Replaces all individual API keys (GitHub, Reddit, Google, etc.)
# Composio manages auth for 250k+ API tools via a single key.
# Get yours at https://composio.dev
COMPOSIO_API_KEY=

# --- Provider Config for Seed Harness -------------------------
# Default provider/model for built agents.
# Can be overridden per-agent in config.ts.
PROVIDER=openrouter
MODEL=anthropic/claude-sonnet-4-6
